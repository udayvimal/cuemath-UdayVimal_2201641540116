# FlashCard Engine Backend — Environment Variables
# Copy this file to .env and fill in values for local development
# NEVER commit .env to git

# AI backend: "ollama" for local dev, "gemini" for production
AI_MODE=ollama

# Ollama (local development only)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# Gemini (production — add this ONLY in Render dashboard, never in code)
GEMINI_API_KEY=your-gemini-api-key-here

# CORS — comma separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app
